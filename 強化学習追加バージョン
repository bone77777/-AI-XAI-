class XaiExplainerV2:
    """マルチステップ対応のXAI説明エンジン"""

    def __init__(self):
        self.feature_weights = {
            "traffic_volume":  0.7,
            "ti_reputation":   0.4,
            "valid_signature": -0.8,
            "internal_process":-0.5,
        }

    def compute_risk(self, logs: dict) -> tuple:
        contributions = {}
        risk_score = 0.0
        for feature, weight in self.feature_weights.items():
            value = logs.get(feature, 0)
            contribution = value * weight
            contributions[feature] = contribution
            risk_score += contribution
        risk_score = max(0.0, min(1.0, risk_score))
        return risk_score, contributions

    def explain_episode(self, env: MultiStepIncidentEnv, logs: dict,
                        contributions: dict, q_values_per_step: list):
        """マルチステップエピソード全体の説明レポート"""
        risk_score = env.risk_score
        time_label = env.TIME_CATEGORIES[env.time_category]
        biz_label = "決算期" if env.is_closing else "通常期"

        print("=" * 70)
        print("  XAI × 処方的AI × DQN強化学習 — マルチステップ統合レポート")
        print("=" * 70)

        # --- STEP 1: XAI 判定根拠 ---
        print("\n┌─ [PHASE 1] XAI：初期リスク判定根拠 ──────────────────────┐")
        for f, c in contributions.items():
            mark = "🚨" if c > 0 else "✅"
            bar = "█" * int(abs(c) * 20)
            direction = "リスク↑" if c > 0 else "安全↑ "
            print(f"│  {mark} {f:18}: {c:+.3f}  {direction} {bar}")
        print(f"│  {'─' * 55}")
        print(f"│  📊 リスク確信度 : {risk_score:.1%}")
        print(f"│  📍 業務コンテキスト: {biz_label} × {time_label}")
        print(f"│  🎭 真の脅威強度 : {env.threat_intensity:.1%}（後から判明）")
        print(f"└{'─' * 60}┘")

        # --- STEP 2: マルチステップ対応の経過 ---
        print(f"\n┌─ [PHASE 2] マルチステップ対応経過 ──────────────────────┐")
        print(f"│  Step │ アクション │ 防御力 │ 被ダメージ │ 健全度 │  報酬  │ 累積報酬 │")
        print(f"│  ─────┼──────────┼────────┼──────────┼────────┼────────┼─────────│")

        for log in env.step_log:
            esc_mark = ""
            if log["step"] > 0:
                prev = env.step_log[log["step"] - 1]["action_idx"]
                curr = log["action_idx"]
                if curr > prev:
                    esc_mark = " ⬆"
                elif curr < prev:
                    esc_mark = " ⬇"

            print(f"│  {log['step']:4d}  │ {log['action']:8}{esc_mark:3}│ "
                  f"{log['defense']:5.0%}  │ {log['damage']:9.3f} │ "
                  f"{log['health']:5.1%}  │ {log['reward']:+6.1f} │ "
                  f"{log['cumulative_reward']:+7.1f}  │")

        final_health = env.system_health
        health_icon = "🟢" if final_health > 0.7 else "🟡" if final_health > 0.3 else "🔴"
        print(f"│  {'─' * 55}")
        print(f"│  {health_icon} 最終健全度: {final_health:.1%}  "
              f"│  エスカレーション: {env.escalation_count}回  "
              f"│  総報酬: {env.cumulative_reward:+.1f}")
        print(f"└{'─' * 60}┘")

        # --- STEP 3: DQNのQ値推移 ---
        if q_values_per_step:
            print(f"\n┌─ [PHASE 3] DQN：各ステップのQ値推移 ──────────────────┐")
            action_names = ["MONITOR", "THROTTLE", "ISOLATE"]
            for i, (q_vals, chosen) in enumerate(q_values_per_step):
                chosen_name = action_names[chosen]
                q_str = "  ".join(
                    f"{name}:{q:+6.1f}{'◀' if name == chosen_name else ' '}"
                    for name, q in zip(action_names, q_vals)
                )
                print(f"│  Step{i}: {q_str}")

            # 行動変遷の解説
            actions_taken = [s[1] for s in q_values_per_step]
            action_labels = [env.ACTIONS[a]["label"] for a in actions_taken]

            print(f"│  {'─' * 55}")
            print(f"│  📋 対応フロー: {' → '.join(action_labels)}")

            # 段階的対応の評価
            had_escalation = any(
                actions_taken[i] > actions_taken[i-1]
                for i in range(1, len(actions_taken))
            )
            had_deescalation = any(
                actions_taken[i] < actions_taken[i-1]
                for i in range(1, len(actions_taken))
            )

            if had_escalation and had_deescalation:
                print(f"│  💡 適応的対応: エスカレーションとデエスカレーションの")
                print(f"│     両方を実施し、状況に応じた柔軟な対応を行いました。")
            elif had_escalation:
                print(f"│  💡 段階的エスカレーション: 脅威の深刻化に応じて")
                print(f"│     防御レベルを段階的に引き上げました。")
            elif had_deescalation:
                print(f"│  💡 デエスカレーション: 状況改善に応じて")
                print(f"│     業務復旧を優先した対応に移行しました。")
            else:
                print(f"│  💡 一貫した対応: 状況評価に基づき、同一レベルの")
                print(f"│     対応を維持しました。")

            print(f"└{'─' * 60}┘")


