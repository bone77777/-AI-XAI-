"""
処方的AI × XAI ＋ 強化学習（DQN） — 完全拡張版
=================================================

拡張1: 状態空間の拡張
  - 過去N回の対応履歴
  - 時間帯（業務時間 / 夜間 / 休日）
  - システム健全度
  - エスカレーション回数

拡張2: Deep Q-Network（DQN）
  - ニューラルネットワークによるQ値近似
  - Experience Replay
  - Target Network（安定学習）

拡張3: マルチステップ意思決定
  - 1インシデントを最大5ステップで対応
  - 段階的エスカレーション／デエスカレーション
  - 観察 → 判断 → 再評価の連続ループ
"""

import numpy as np
import random
from collections import deque, defaultdict
import torch
import torch.nn as nn
import torch.optim as optim

# 再現性のためのシード
SEED = 42
random.seed(SEED)
np.random.seed(SEED)
torch.manual_seed(SEED)


# =============================================================================
# 1. 拡張環境（Multi-Step Incident Response Environment）
# =============================================================================
class MultiStepIncidentEnv:
    """
    マルチステップ対応のインシデント環境。
    1インシデントを最大MAX_STEPSステップで対応し、
    各ステップでエージェントが行動を選択 → 環境が遷移する。
    """

    MAX_STEPS = 5  # 1インシデントあたりの最大ステップ数

    # 行動空間（3アクション）
    ACTIONS = {
        0: {"name": "MONITOR",  "label": "監視のみ",  "defense": 0.1, "disruption": 0.02},
        1: {"name": "THROTTLE", "label": "帯域制限",  "defense": 0.6, "disruption": 0.15},
        2: {"name": "ISOLATE",  "label": "完全遮断",  "defense": 1.0, "disruption": 1.00},
    }

    # 時間帯カテゴリ
    TIME_CATEGORIES = {
        0: "業務時間",
        1: "夜間",
        2: "休日",
    }

    N_ACTIONS = 3
    HISTORY_LEN = 3  # 過去N回の行動履歴

    # 状態ベクトルの次元数:
    #   risk_score(1) + is_closing(1) + time_category_onehot(3)
    #   + system_health(1) + escalation_count(1) + current_step(1)
    #   + action_history(HISTORY_LEN) + threat_intensity(1)
    STATE_DIM = 1 + 1 + 3 + 1 + 1 + 1 + HISTORY_LEN + 1  # = 12

    def __init__(self):
        self.reset()

    def reset(self, risk_score=None, is_closing=None, time_cat=None,
              threat_intensity=None):
        """新しいインシデントのエピソードを開始"""

        # ランダム生成 or 指定
        self.risk_score = risk_score if risk_score is not None else random.random()
        self.is_closing = is_closing if is_closing is not None else (random.random() < 0.3)
        self.time_category = time_cat if time_cat is not None else random.choice([0, 1, 2])

        # 脅威の真の強度（エージェントには直接見えない — risk_scoreは推定値）
        if threat_intensity is not None:
            self.threat_intensity = threat_intensity
        else:
            # risk_scoreにノイズを加えた真の脅威レベル
            noise = np.clip(np.random.normal(0, 0.15), -0.3, 0.3)
            self.threat_intensity = np.clip(self.risk_score + noise, 0, 1)

        # 動的状態
        self.system_health = 1.0         # システム健全度 (0~1)
        self.escalation_count = 0        # エスカレーション回数
        self.current_step = 0            # 現在のステップ
        self.action_history = [-1] * self.HISTORY_LEN  # 過去の行動（-1=未実行）
        self.done = False
        self.cumulative_reward = 0.0

        # エピソードログ
        self.step_log = []

        return self._get_state_vector()

    def _get_state_vector(self) -> np.ndarray:
        """現在の状態を連続ベクトルに変換"""
        vec = []

        # (1) リスクスコア
        vec.append(self.risk_score)

        # (2) 決算期フラグ
        vec.append(1.0 if self.is_closing else 0.0)

        # (3) 時間帯（one-hot）
        time_onehot = [0.0, 0.0, 0.0]
        time_onehot[self.time_category] = 1.0
        vec.extend(time_onehot)

        # (4) システム健全度
        vec.append(self.system_health)

        # (5) エスカレーション回数（正規化）
        vec.append(self.escalation_count / self.MAX_STEPS)

        # (6) 現在のステップ（正規化）
        vec.append(self.current_step / self.MAX_STEPS)

        # (7) 過去の行動履歴（-1を0に、0/1/2を正規化）
        for a in self.action_history:
            vec.append((a + 1) / 3.0)  # -1→0, 0→0.33, 1→0.67, 2→1.0

        # (8) 脅威の推定強度（観測可能なリスク指標）
        # 実際のシステムではIDS/IPSの出力に相当
        observable_threat = np.clip(
            self.threat_intensity + np.random.normal(0, 0.05), 0, 1
        )
        vec.append(observable_threat)

        return np.array(vec, dtype=np.float32)

    def step(self, action: int):
        """
        1ステップ実行。
        Returns: (next_state, reward, done, info)
        """
        if self.done:
            raise RuntimeError("Episode already done. Call reset().")

        act = self.ACTIONS[action]
        prev_action = self.action_history[-1] if self.action_history[-1] != -1 else None

        # --- エスカレーション検出 ---
        if prev_action is not None and action > prev_action:
            self.escalation_count += 1

        # --- 行動履歴の更新 ---
        self.action_history.pop(0)
        self.action_history.append(action)

        # --- ビジネス影響の重み ---
        biz_weight = 1.0
        if self.is_closing:
            biz_weight *= 2.0
        if self.time_category == 0:  # 業務時間中
            biz_weight *= 1.5
        elif self.time_category == 2:  # 休日
            biz_weight *= 0.5

        # --- 脅威によるダメージ計算 ---
        # 防御力が足りないと、脅威がシステムにダメージを与える
        unmitigated = max(0, self.threat_intensity - act["defense"])
        damage = unmitigated * 0.25  # 1ステップあたりの最大ダメージ
        self.system_health = max(0, self.system_health - damage)

        # --- 報酬計算 ---
        reward = self._compute_reward(action, act, damage, biz_weight)
        self.cumulative_reward += reward

        # --- ステップログ ---
        self.step_log.append({
            "step": self.current_step,
            "action": act["label"],
            "action_idx": action,
            "defense": act["defense"],
            "damage": damage,
            "health": self.system_health,
            "reward": reward,
            "cumulative_reward": self.cumulative_reward,
        })

        # --- 終了判定 ---
        self.current_step += 1
        if self.current_step >= self.MAX_STEPS:
            self.done = True
        if self.system_health <= 0:
            self.done = True  # システムダウン

        # 脅威が完全に無力化された場合
        if self.threat_intensity < 0.1 and act["defense"] >= 0.5:
            self.done = True

        next_state = self._get_state_vector()

        info = {
            "health": self.system_health,
            "threat_intensity": self.threat_intensity,
            "escalation_count": self.escalation_count,
            "step": self.current_step,
        }

        return next_state, reward, self.done, info

    def _compute_reward(self, action, act, damage, biz_weight):
        """
        =====================================================
        報酬関数（拡張版）
        =====================================================

        R = R_defense + R_health + R_disruption + R_escalation

        R_defense   : 脅威を防いだ報酬 / 見逃しペナルティ
        R_health    : システム健全度の維持報酬
        R_disruption: 業務中断ペナルティ（業務時間×決算期で増幅）
        R_escalation: 段階的対応のボーナス / 過剰反応ペナルティ
        """

        reward = 0.0

        # --- R_defense: 防御成果 ---
        if self.threat_intensity >= 0.5:
            # 高脅威時: 防御力に応じた報酬
            if act["defense"] >= 0.6:
                reward += 8.0 * act["defense"]
            else:
                # 見逃しペナルティ（脅威が高いほど大きい）
                reward -= 15.0 * self.threat_intensity
        else:
            # 低脅威時: 静観が正解
            if act["defense"] <= 0.3:
                reward += 3.0  # 適切な静観
            else:
                reward -= 3.0 * act["disruption"] * biz_weight  # 過剰対応

        # --- R_health: システム健全度 ---
        if damage > 0:
            reward -= damage * 20.0  # ダメージは常に悪い
        if self.system_health > 0.8:
            reward += 1.0  # 健全度維持ボーナス

        # --- R_disruption: 業務中断コスト ---
        disruption_cost = act["disruption"] * 5.0 * biz_weight
        reward -= disruption_cost

        # --- R_escalation: 段階的対応 ---
        prev = self.action_history[-2] if len(self.action_history) >= 2 and self.action_history[-2] != -1 else None
        if prev is not None:
            if action > prev and self.threat_intensity >= 0.5:
                # 脅威が高い状況でのエスカレーション → ボーナス
                reward += 3.0
            elif action > prev and self.threat_intensity < 0.3:
                # 低脅威でのエスカレーション → ペナルティ
                reward -= 4.0 * biz_weight
            elif action < prev and self.threat_intensity < 0.3:
                # 脅威低下時のデエスカレーション → ボーナス
                reward += 2.0

        # --- 終局ボーナス/ペナルティ ---
        if self.system_health <= 0:
            reward -= 50.0  # システムダウンは致命的
        elif self.done and self.system_health > 0.7:
            reward += 10.0  # 健全な状態でインシデント解決

        return reward


