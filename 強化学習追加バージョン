# 4. 統合システム
# =============================================================================
class PrescriptiveAI_DQN:
    """処方的AI × XAI × DQN強化学習 の統合システム（完全拡張版）"""

    def __init__(self):
        self.env = MultiStepIncidentEnv()
        self.agent = DQNAgent(
            state_dim=self.env.STATE_DIM,
            n_actions=self.env.N_ACTIONS,
            lr=5e-4,
            gamma=0.95,
            epsilon=1.0,
            epsilon_decay=0.9997,
            epsilon_min=0.05,
            batch_size=64,
            target_update_freq=200,
        )
        self.explainer = XaiExplainerV2()

        # 学習メトリクス
        self.episode_rewards_log = []

    def train(self, n_episodes=8000, verbose=True):
        """DQNトレーニング（マルチステップエピソード）"""
        if verbose:
            print("=" * 70)
            print("  DQN強化学習トレーニング開始")
            print(f"  エピソード数: {n_episodes} | 状態次元: {self.env.STATE_DIM}")
            print(f"  最大ステップ/ep: {self.env.MAX_STEPS} | バッチサイズ: {self.agent.batch_size}")
            print("=" * 70)

        reward_window = deque(maxlen=500)

        for ep in range(n_episodes):
            state = self.env.reset()
            episode_reward = 0.0

            while not self.env.done:
                action = self.agent.choose_action(state, training=True)
                next_state, reward, done, info = self.env.step(action)

                self.agent.store_transition(state, action, reward, next_state, done)
                loss = self.agent.train_step()

                state = next_state
                episode_reward += reward

            self.agent.decay_epsilon()
            self.episode_rewards_log.append(episode_reward)
            reward_window.append(episode_reward)

            if verbose and (ep + 1) % 1000 == 0:
                avg_r = np.mean(reward_window)
                avg_loss = np.mean(self.agent.losses[-500:]) if self.agent.losses else 0
                print(f"  Episode {ep+1:5d} | "
                      f"平均報酬: {avg_r:+7.2f} | "
                      f"損失: {avg_loss:.4f} | "
                      f"ε: {self.agent.epsilon:.4f}")

        if verbose:
            print(f"\n  ✅ トレーニング完了！")
            print(f"     総学習ステップ: {self.agent.train_steps}")
            print(f"     最終ε: {self.agent.epsilon:.4f}")
            print(f"     最終平均報酬(500ep): {np.mean(list(reward_window)):+.2f}")
            self._print_policy_analysis()

    def _print_policy_analysis(self):
        """学習済み方策の分析"""
        print(f"\n┌─ 学習済み方策の分析 ──────────────────────────────────┐")

        scenarios = [
            ("LOW×通常期×業務時間",    0.15, False, 0),
            ("LOW×決算期×業務時間",    0.15, True,  0),
            ("MEDIUM×通常期×業務時間", 0.45, False, 0),
            ("MEDIUM×決算期×業務時間", 0.45, True,  0),
            ("HIGH×通常期×業務時間",   0.75, False, 0),
            ("HIGH×決算期×業務時間",   0.75, True,  0),
            ("HIGH×通常期×夜間",       0.75, False, 1),
            ("HIGH×決算期×休日",       0.75, True,  2),
            ("CRITICAL×通常期×業務時間", 0.95, False, 0),
            ("CRITICAL×決算期×業務時間", 0.95, True,  0),
        ]

        print(f"│  {'シナリオ':30} │ {'MONITOR':>8} {'THROTTLE':>9} {'ISOLATE':>8} │ {'初手':>8} │")
        print(f"│  {'─'*30}─┼{'─'*28}─┼{'─'*9}─│")

        for label, risk, closing, time_cat in scenarios:
            state = self.env.reset(
                risk_score=risk, is_closing=closing, time_cat=time_cat,
                threat_intensity=risk  # 分析用に真値=推定値
            )
            q_vals = self.agent.get_q_values(state)
            best_action = self.env.ACTIONS[int(np.argmax(q_vals))]["label"]
            print(f"│  {label:30} │ {q_vals[0]:+8.1f} {q_vals[1]:+9.1f} {q_vals[2]:+8.1f} │ {best_action:>8} │")

        print(f"└{'─' * 70}┘")

    def predict(self, logs: dict, business_context: dict, time_category: int = 0):
        """
        推論フェーズ: マルチステップ対応の実行とXAI説明
        """
        # XAIでリスク算出
        risk_score, contributions = self.explainer.compute_risk(logs)

        is_closing = business_context.get("is_closing_period", False)

        # エピソードの開始
        state = self.env.reset(
            risk_score=risk_score,
            is_closing=is_closing,
            time_cat=time_category,
        )

        # マルチステップ実行
        q_values_per_step = []

        while not self.env.done:
            q_vals = self.agent.get_q_values(state)
            action = self.agent.choose_action(state, training=False)
            q_values_per_step.append((q_vals.tolist(), action))

            next_state, reward, done, info = self.env.step(action)
            state = next_state

        # XAI統合レポート
        self.explainer.explain_episode(self.env, logs, contributions, q_values_per_step)

        return {
            "risk_score": risk_score,
            "contributions": contributions,
            "final_health": self.env.system_health,
            "total_reward": self.env.cumulative_reward,
            "steps": len(self.env.step_log),
            "step_log": self.env.step_log,
        }


